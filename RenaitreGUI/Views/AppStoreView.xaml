<Page x:Class="RenaitreGUI.Views.AppStoreView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgPrimaryBrush}">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="APP STORE" Foreground="{StaticResource AccentGreenBrush}"
                   FontFamily="Cascadia Mono, Consolas" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="0" Text="winget powered package manager" VerticalAlignment="Bottom"
                   Foreground="{StaticResource TextMutedBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" Margin="0,0,0,-16"/>

        <!-- Search bar -->
        <Grid Grid.Row="1" Margin="0,24,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0"
                     Background="{StaticResource BgCardBrush}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource BorderBrush2}"
                     FontFamily="Cascadia Mono, Consolas"
                     Padding="12,8" FontSize="13"
                     KeyDown="SearchBox_KeyDown"
                     Text="" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="Search" Style="{StaticResource ActionButtonStyle}"
                    Click="SearchBtn_Click" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Upgrade All" Style="{StaticResource ActionButtonStyle}"
                    Click="UpgradeAllBtn_Click"/>
        </Grid>

        <!-- Quick install buttons -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="Quick Install: " Foreground="{StaticResource TextMutedBrush}"
                       FontFamily="Cascadia Mono, Consolas" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button Content="Steam" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,6"
                    Click="QuickInstall_Click" Tag="Valve.Steam"/>
            <Button Content="Discord" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,6"
                    Click="QuickInstall_Click" Tag="Discord.Discord"/>
            <Button Content="VS Code" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,6"
                    Click="QuickInstall_Click" Tag="Microsoft.VisualStudioCode"/>
            <Button Content="Python 3" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,6"
                    Click="QuickInstall_Click" Tag="Python.Python.3"/>
            <Button Content="Notepad++" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,6"
                    Click="QuickInstall_Click" Tag="Notepad++.Notepad++"/>
            <Button Content="PyCharm CE" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,6"
                    Click="QuickInstall_Click" Tag="JetBrains.PyCharm.Community"/>
            <Button Content="IntelliJ CE" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,6"
                    Click="QuickInstall_Click" Tag="JetBrains.IntelliJIDEA.Community"/>
            <Button Content="Epic Games" Style="{StaticResource ActionButtonStyle}" Margin="0,0,6,6"
                    Click="QuickInstall_Click" Tag="EpicGames.EpicGamesLauncher"/>
        </WrapPanel>

        <!-- Search Results Panel (visible after a search) -->
        <Border Grid.Row="3" x:Name="ResultsBorder" Visibility="Collapsed"
                Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="1" CornerRadius="4" Margin="0,0,0,12" Padding="10,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock x:Name="ResultsCountText" Text="RESULTS"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold"
                               DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock Text="Click Install to install a package"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontFamily="Cascadia Mono, Consolas" FontSize="10"
                               DockPanel.Dock="Right" VerticalAlignment="Center"/>
                </DockPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                    <StackPanel x:Name="ResultsList"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Custom install by ID -->
        <Grid Grid.Row="4" Margin="0,0,0,16" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="CustomIdBox" Grid.Column="0"
                     Background="{StaticResource BgCardBrush}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource BorderBrush2}"
                     FontFamily="Cascadia Mono, Consolas"
                     Padding="12,8" FontSize="12" Margin="0,0,8,0"
                     Tag="Enter winget package ID (e.g. Microsoft.WindowsTerminal)"
                     GotFocus="CustomIdBox_GotFocus" LostFocus="CustomIdBox_LostFocus"/>
            <Button Grid.Column="1" Content="Install by ID" Style="{StaticResource ActionButtonStyle}"
                    Click="InstallById_Click"/>
        </Grid>

        <!-- Terminal output -->
        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="OUTPUT" Foreground="{StaticResource TextMutedBrush}"
                           FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="StopBtn" Content="Stop" Style="{StaticResource DangerButtonStyle}"
                            Padding="12,4" FontSize="11" Click="StopBtn_Click" IsEnabled="False" Margin="0,0,8,0"/>
                    <Button Content="Clear" Style="{StaticResource ActionButtonStyle}"
                            Padding="12,4" FontSize="11" Click="ClearBtn_Click"/>
                </StackPanel>
            </DockPanel>
            <TextBox x:Name="TerminalOutput" Grid.Row="1" Style="{StaticResource TerminalStyle}"
                     Text="> Ready. Search for apps or use quick install buttons above.&#xa;"/>
        </Grid>
    </Grid>
</Page>
