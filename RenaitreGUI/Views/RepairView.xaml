<Page x:Class="RenaitreGUI.Views.RepairView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgPrimaryBrush}">

    <Grid Margin="28,20,28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="REPAIR CENTER" FontFamily="Cascadia Mono, Consolas"
                       FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"
                       Effect="{StaticResource GlowMagenta}"/>
            <TextBlock Text="tek tıkla sistem onarımı ve bakımı" FontFamily="Cascadia Mono, Consolas"
                       FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Sections -->
        <StackPanel Grid.Row="1" Margin="0,0,0,4">
            <TextBlock Text="// SİSTEM ONARIM" Foreground="{StaticResource AccentVioletBrush}"
                       FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <WrapPanel Margin="0,0,0,14">
                <Button Content="SFC Tarama" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8"
                        Click="RunTool_Click" Tag="SFC" ToolTip="sfc /scannow — bozuk sistem dosyalarını tarar/onarır"/>
                <Button Content="DISM Onarım" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8"
                        Click="RunTool_Click" Tag="DISM" ToolTip="DISM /RestoreHealth — Windows bileşen deposunu onarır"/>
                <Button Content="Disk Kontrol" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8"
                        Click="RunTool_Click" Tag="CHKDSK" ToolTip="chkdsk C: /scan — çevrimiçi disk taraması (yeniden başlatma yok)"/>
                <Button Content="Geri Yükleme Noktası" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8"
                        Click="RunTool_Click" Tag="RESTORE_POINT" ToolTip="Riskli işlemden önce sistem geri yükleme noktası oluşturur"/>
            </WrapPanel>

            <TextBlock Text="// TEMİZLİK" Foreground="{StaticResource AccentVioletBrush}"
                       FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <WrapPanel Margin="0,0,0,14">
                <Button Content="Temp Temizle" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8"
                        Click="RunTool_Click" Tag="CLEAR_TEMP" ToolTip="Kullanıcı ve Windows temp klasörlerini temizler"/>
                <Button Content="Geri Dönüşüm Kutusu" Style="{StaticResource DangerButtonStyle}" Margin="0,0,8,8"
                        Click="DangerTool_Click" Tag="EMPTY_RECYCLE" ToolTip="Geri dönüşüm kutusunu boşaltır (geri alınamaz)"/>
                <Button Content="Store Önbelleği" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8"
                        Click="RunTool_Click" Tag="WSRESET" ToolTip="wsreset — Microsoft Store önbelleğini sıfırlar"/>
            </WrapPanel>

            <TextBlock Text="// HIZLI DÜZELTME" Foreground="{StaticResource AccentVioletBrush}"
                       FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <WrapPanel Margin="0,0,0,4">
                <Button Content="DNS Temizle" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8"
                        Click="RunTool_Click" Tag="DNS_FLUSH" ToolTip="ipconfig /flushdns"/>
                <Button Content="Explorer Yeniden Başlat" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8"
                        Click="RunTool_Click" Tag="RESTART_EXPLORER" ToolTip="Donmuş masaüstü/görev çubuğu için explorer.exe'yi yeniden başlatır"/>
            </WrapPanel>
        </StackPanel>

        <!-- Terminal -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                <TextBlock Text="// OUTPUT" Foreground="{StaticResource AccentVioletBrush}"
                           FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="StopBtn" Content="Stop" Style="{StaticResource DangerButtonStyle}"
                            Padding="12,4" FontSize="11" Click="StopBtn_Click" IsEnabled="False" Margin="0,0,8,0"/>
                    <Button Content="Clear" Style="{StaticResource ActionButtonStyle}"
                            Padding="12,4" FontSize="11" Click="ClearBtn_Click"/>
                </StackPanel>
            </DockPanel>
            <TextBox x:Name="TerminalOutput" Grid.Row="1" Style="{StaticResource TerminalStyle}"
                     Text="> Repair Center hazır. Bir araç seç.&#xa;"/>
        </Grid>
    </Grid>
</Page>
