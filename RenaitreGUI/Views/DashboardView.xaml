<Page x:Class="RenaitreGUI.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgPrimaryBrush}">

    <Grid Margin="28,20,28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="DASHBOARD" FontFamily="Cascadia Mono, Consolas"
                       FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"
                       Effect="{StaticResource GlowMagenta}"/>
            <TextBlock Text="system control interface · v2.0" FontFamily="Cascadia Mono, Consolas"
                       FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- System Overview -->
        <StackPanel Grid.Row="1" Margin="0,0,0,18">
            <TextBlock Text="// SYSTEM OVERVIEW" Foreground="{StaticResource AccentVioletBrush}"
                       FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <UniformGrid Columns="3" Margin="0,0,-10,0">
                <Border Style="{StaticResource ToolCardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="◈ USER" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontFamily="Cascadia Mono, Consolas"/>
                        <TextBlock x:Name="TxtUser" Foreground="{StaticResource AccentCyanBrush}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ToolCardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="▣ MACHINE" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontFamily="Cascadia Mono, Consolas"/>
                        <TextBlock x:Name="TxtMachine" Foreground="{StaticResource AccentCyanBrush}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ToolCardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="⛨ PRIVILEGE" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontFamily="Cascadia Mono, Consolas"/>
                        <TextBlock x:Name="TxtPrivilege" FontFamily="Cascadia Mono, Consolas"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>

        <!-- System Health · Live (CPU + RAM + dinamik diskler) -->
        <StackPanel Grid.Row="2" Margin="0,0,0,18">
            <TextBlock Text="// SYSTEM HEALTH · LIVE" Foreground="{StaticResource AccentVioletBrush}"
                       FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <UniformGrid x:Name="HealthGrid" Columns="2" Margin="0,0,-10,0">
                <!-- CPU -->
                <Border Style="{StaticResource ToolCardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="CPU" Foreground="{StaticResource TextMutedBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TxtCpu" Text="--%" Foreground="#FFFFFF" FontFamily="Cascadia Mono, Consolas" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Style="{StaticResource MeterTrackStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="CpuFill" Width="0*"/>
                                    <ColumnDefinition x:Name="CpuRest" Width="100*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{StaticResource MeterCpuFill}" CornerRadius="6" Effect="{StaticResource GlowMagenta}"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="TxtCpuSub" Text="" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="10" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <!-- RAM -->
                <Border Style="{StaticResource ToolCardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="RAM" Foreground="{StaticResource TextMutedBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TxtRam" Text="--%" Foreground="#FFFFFF" FontFamily="Cascadia Mono, Consolas" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Style="{StaticResource MeterTrackStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="RamFill" Width="0*"/>
                                    <ColumnDefinition x:Name="RamRest" Width="100*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{StaticResource MeterRamFill}" CornerRadius="6" Effect="{StaticResource GlowCyan}"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="TxtRamSub" Text="" Foreground="{StaticResource TextDimBrush}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="10" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Disk ölçerleri kod tarafında eklenir -->
            </UniformGrid>
        </StackPanel>

        <!-- Quick Actions -->
        <StackPanel Grid.Row="3" Margin="0,0,0,18">
            <TextBlock Text="// QUICK ACTIONS" Foreground="{StaticResource AccentVioletBrush}"
                       FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <UniformGrid Columns="4" Margin="0,0,-10,0">
                <Button Content="ipconfig /all" Style="{StaticResource ActionButtonStyle}"
                        Margin="0,0,10,0" Click="QuickAction_Click" Tag="ipconfig /all"/>
                <Button Content="netstat -ano" Style="{StaticResource ActionButtonStyle}"
                        Margin="0,0,10,0" Click="QuickAction_Click" Tag="netstat -ano"/>
                <Button Content="systeminfo" Style="{StaticResource ActionButtonStyle}"
                        Margin="0,0,10,0" Click="QuickAction_Click" Tag="systeminfo"/>
                <Button Content="winget upgrade" Style="{StaticResource ActionButtonStyle}"
                        Margin="0,0,10,0" Click="QuickAction_Click" Tag="winget upgrade --all"/>
            </UniformGrid>
        </StackPanel>

        <!-- Terminal output (kalan alanı doldurur) -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="// OUTPUT" Foreground="{StaticResource AccentVioletBrush}"
                       FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBox x:Name="TerminalOutput" Grid.Row="1" Style="{StaticResource TerminalStyle}"
                     Text="RenaitreSabre v2.0 — ready.&#xa;&gt; "/>
        </Grid>
    </Grid>
</Page>
