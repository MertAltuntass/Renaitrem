<Page x:Class="RenaitreGUI.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20">

            <TextBlock Text="SETTINGS" FontFamily="Cascadia Mono, Consolas"
                       FontSize="24" FontWeight="Bold" Foreground="#FFFFFF"
                       Effect="{StaticResource GlowMagenta}"/>
            <TextBlock Text="uygulama yapılandırması ve tanılama" FontFamily="Cascadia Mono, Consolas"
                       FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,22"/>

            <!-- OUTPUT & LOGS -->
            <TextBlock Text="// ÇIKTI &amp; LOGLAR" Foreground="{StaticResource AccentVioletBrush}"
                       FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Border Style="{StaticResource ToolCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Script çıktıları, transcript ve hata logları buraya yazılır:"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                    <TextBlock x:Name="TxtOutputPath" Foreground="{StaticResource AccentCyanBrush}"
                               FontFamily="Cascadia Mono, Consolas" FontSize="12" Margin="0,6,0,14" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Klasörü Aç" Style="{StaticResource ActionButtonStyle}"
                                Margin="0,0,10,0" Click="OpenFolder_Click"/>
                        <Button Content="Hata Log'unu Aç" Style="{StaticResource ActionButtonStyle}"
                                Margin="0,0,10,0" Click="OpenLog_Click"/>
                        <Button Content="Logları Temizle" Style="{StaticResource DangerButtonStyle}"
                                Click="ClearLogs_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtLogInfo" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="Cascadia Mono, Consolas" FontSize="10" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- ABOUT -->
            <TextBlock Text="// HAKKINDA" Foreground="{StaticResource AccentVioletBrush}"
                       FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Border Style="{StaticResource ToolCardStyle}">
                <StackPanel>
                    <TextBlock Text="RenaitreSabre v2.0" Foreground="{StaticResource AccentMagentaBrush}"
                               FontFamily="Cascadia Mono, Consolas" FontSize="15" FontWeight="Bold"/>
                    <TextBlock Text="Windows IT / Sistem / Ağ / Pentest araç kiti"
                               Foreground="{StaticResource TextMutedBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11" Margin="0,4,0,14"/>
                    <TextBlock x:Name="TxtAbout" Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Cascadia Mono, Consolas" FontSize="12" LineHeight="20"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
