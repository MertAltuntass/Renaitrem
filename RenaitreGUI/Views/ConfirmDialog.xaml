<Window x:Class="RenaitreGUI.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="12" Background="{StaticResource BgSidebarBrush}"
            BorderBrush="{StaticResource BorderBrush3}" BorderThickness="1" Margin="16"
            MaxWidth="440">
        <Border.Effect>
            <DropShadowEffect x:Name="GlowFx" Color="#FF2E97" BlurRadius="30" ShadowDepth="0" Opacity="0.45"/>
        </Border.Effect>
        <StackPanel Margin="26,22">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock x:Name="IconText" Text="⚠" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{StaticResource AccentMagentaBrush}"/>
                <TextBlock x:Name="TitleText" Text="Onay" FontFamily="Cascadia Mono, Consolas"
                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="#FFFFFF"/>
            </StackPanel>

            <TextBlock x:Name="MessageText" TextWrapping="Wrap" LineHeight="19"
                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,22"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="İptal" Style="{StaticResource ActionButtonStyle}"
                        MinWidth="90" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button x:Name="ConfirmBtn" Content="Devam" Style="{StaticResource DangerButtonStyle}"
                        MinWidth="90" Click="Confirm_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
