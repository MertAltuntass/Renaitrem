<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         CYBERPUNK PALETTE — violet-black zemin, neon magenta + cyan
         ============================================================ -->
    <Color x:Key="BgPrimary">#08060F</Color>
    <Color x:Key="BgSidebar">#0E0A1B</Color>
    <Color x:Key="BgCard">#170F2E</Color>
    <Color x:Key="BgCard2">#1A1330</Color>
    <Color x:Key="BgTerminal">#050409</Color>

    <Color x:Key="AccentMagenta">#FF2E97</Color>
    <Color x:Key="AccentCyan">#1EE9E0</Color>
    <Color x:Key="AccentViolet">#9D4EDD</Color>
    <Color x:Key="AccentSuccess">#3DFF9E</Color>
    <Color x:Key="AccentRed">#FF3B54</Color>
    <Color x:Key="AccentAmber">#FFB020</Color>

    <Color x:Key="TextPrimary">#EAE4FA</Color>
    <Color x:Key="TextMuted">#8A7CB3</Color>
    <Color x:Key="TextDim">#5A4E7E</Color>
    <Color x:Key="BorderColor">#2A1E4A</Color>
    <Color x:Key="BorderColor2">#3A2A63</Color>

    <!-- Semantic brushes -->
    <SolidColorBrush x:Key="BgPrimaryBrush"   Color="{StaticResource BgPrimary}"/>
    <SolidColorBrush x:Key="BgSidebarBrush"   Color="{StaticResource BgSidebar}"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgTerminalBrush"  Color="{StaticResource BgTerminal}"/>
    <SolidColorBrush x:Key="AccentMagentaBrush" Color="{StaticResource AccentMagenta}"/>
    <SolidColorBrush x:Key="AccentCyanBrush"  Color="{StaticResource AccentCyan}"/>
    <SolidColorBrush x:Key="AccentVioletBrush" Color="{StaticResource AccentViolet}"/>
    <SolidColorBrush x:Key="AccentSuccessBrush" Color="{StaticResource AccentSuccess}"/>
    <SolidColorBrush x:Key="AccentRedBrush"   Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="AccentAmberBrush" Color="{StaticResource AccentAmber}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"   Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="TextDimBrush"     Color="{StaticResource TextDim}"/>
    <SolidColorBrush x:Key="BorderBrush2"     Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderBrush3"     Color="{StaticResource BorderColor2}"/>

    <!-- Geriye dönük uyumluluk alias'ları: eski view'lar "AccentGreenBrush"i
         başlık rengi olarak kullanıyor → artık neon magenta'ya işaret ediyor,
         böylece diğer sayfalar dokunmadan cyberpunk oluyor. -->
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentMagenta}"/>

    <!-- Gradyan fırçalar -->
    <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource AccentMagenta}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentCyan}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource BgCard2}" Offset="0"/>
        <GradientStop Color="{StaticResource BgCard}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MeterCpuFill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource AccentCyan}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentMagenta}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MeterRamFill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource AccentViolet}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentCyan}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MeterDiskFill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource AccentSuccess}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentCyan}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="NavActiveGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#33FF2E97" Offset="0"/>
        <GradientStop Color="#0D9D4EDD" Offset="1"/>
    </LinearGradientBrush>

    <!-- Neon glow efektleri (paylaşılabilir Freezable) -->
    <DropShadowEffect x:Key="GlowMagenta" Color="{StaticResource AccentMagenta}" BlurRadius="18" ShadowDepth="0" Opacity="0.55"/>
    <DropShadowEffect x:Key="GlowCyan"    Color="{StaticResource AccentCyan}"    BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
    <DropShadowEffect x:Key="GlowSuccess" Color="{StaticResource AccentSuccess}" BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
    <DropShadowEffect x:Key="GlowSoft"    Color="{StaticResource AccentMagenta}" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>

    <!-- ============================================================
         SIDEBAR NAV
         ============================================================ -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="46"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="9" BorderThickness="1" BorderBrush="Transparent"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#141024"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border Background="{StaticResource NavActiveGradient}"
                                CornerRadius="9" BorderThickness="1"
                                BorderBrush="#59FF2E97" Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource GlowSoft}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="3" HorizontalAlignment="Left" Margin="0,7" CornerRadius="3"
                                Background="{StaticResource BrandGradient}" Effect="{StaticResource GlowMagenta}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         TERMINAL
         ============================================================ -->
    <Style x:Key="TerminalStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BgTerminalBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentSuccessBrush}"/>
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush3}"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="CaretBrush" Value="{StaticResource AccentSuccessBrush}"/>
    </Style>

    <!-- ============================================================
         KARTLAR
         ============================================================ -->
    <Style x:Key="ToolCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardGradient}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ============================================================
         BUTONLAR
         ============================================================ -->
    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush3}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" CornerRadius="8" Padding="{TemplateBinding Padding}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#141EE9E0" Offset="0"/>
                                <GradientStop Color="#0AFF2E97" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentMagentaBrush}"/>
                            <Setter TargetName="b" Property="Effect" Value="{StaticResource GlowSoft}"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
        <Setter Property="BorderBrush" Value="#66FF3B54"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" CornerRadius="8" Padding="{TemplateBinding Padding}"
                            Background="#1AFF3B54"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                            <Setter TargetName="b" Property="Background" Value="#33FF3B54"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Meter (ilerleme çubuğu) container stili -->
    <Style x:Key="MeterTrackStyle" TargetType="Border">
        <Setter Property="Height" Value="8"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="#0B0818"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

</ResourceDictionary>
