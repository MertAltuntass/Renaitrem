<Window x:Class="RenaitreGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="RenaitreSabre" Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        BorderThickness="0"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border BorderThickness="1" BorderBrush="{StaticResource BorderBrush3}" CornerRadius="10"
            Background="{StaticResource BgPrimaryBrush}" Margin="14">
        <Border.Effect>
            <DropShadowEffect Color="#9D4EDD" BlurRadius="28" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>   <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0" Background="{StaticResource BgSidebarBrush}"
                    CornerRadius="10,10,0,0" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <Ellipse x:Name="OnlineDot" Width="9" Height="9" Margin="0,0,9,0"
                                 Fill="{StaticResource AccentSuccessBrush}" Effect="{StaticResource GlowSuccess}">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.25" Duration="0:0:0.9"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="RenaitreSabre" Foreground="{StaticResource BrandGradient}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="14" FontWeight="Bold"
                                   Effect="{StaticResource GlowSoft}"/>
                        <TextBlock x:Name="AdminBadge" Text=" [ADMIN]" Foreground="{StaticResource AccentCyanBrush}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- System online indicator -->
                    <TextBlock Grid.Column="1" Text="◆ SYSTEM ONLINE" VerticalAlignment="Center"
                               Margin="0,0,16,0" Foreground="{StaticResource AccentCyanBrush}"
                               FontFamily="Cascadia Mono, Consolas" FontSize="10"/>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="─" Click="MinimizeBtn_Click"
                                Width="32" Height="28" Background="Transparent"
                                Foreground="{StaticResource TextMutedBrush}" BorderThickness="0"
                                FontSize="14" Cursor="Hand"/>
                        <Button Content="✕" Click="CloseBtn_Click"
                                Width="32" Height="28" Background="Transparent"
                                Foreground="{StaticResource TextMutedBrush}" BorderThickness="0"
                                FontSize="12" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource BgSidebarBrush}"
                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,1,0">
                    <StackPanel>
                        <TextBlock Text="NAVIGATION" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="16,16,0,8"
                                   FontFamily="Cascadia Mono, Consolas"/>

                        <Button x:Name="BtnDashboard" Content="⬛  Dashboard"
                                Style="{StaticResource NavButtonActiveStyle}"
                                Click="NavBtn_Click" Tag="Dashboard"/>
                        <Button x:Name="BtnAppStore" Content="🛒  App Store"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavBtn_Click" Tag="AppStore"/>
                        <Button x:Name="BtnRepair" Content="🛠  Repair Center"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavBtn_Click" Tag="Repair"/>
                        <Button x:Name="BtnNetwork" Content="🌐  Network Tools"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavBtn_Click" Tag="Network"/>
                        <Button x:Name="BtnSecurity" Content="🛡  Security"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavBtn_Click" Tag="Security"/>
                        <Button x:Name="BtnPentest" Content="⚔️  Pentest Tools"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavBtn_Click" Tag="Pentest"/>
                        <Button x:Name="BtnSabre" Content="🔥  Sabre (Overkill)"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavBtn_Click" Tag="Sabre"/>
                        <Button x:Name="BtnSettings" Content="⚙  Settings"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavBtn_Click" Tag="Settings"/>

                        <!-- Spacer -->
                        <Separator Background="{StaticResource BorderBrush2}" Margin="16,16"/>

                        <TextBlock x:Name="ClockText"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                   Margin="16,0" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Content area -->
                <Frame x:Name="ContentFrame" Grid.Column="1"
                       NavigationUIVisibility="Hidden"
                       Background="{StaticResource BgPrimaryBrush}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
